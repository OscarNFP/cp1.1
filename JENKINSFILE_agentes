pipeline{
    // Cualquier agente disponible para ejecutar el pipeline
    agent any
    
    // Evitar el checkout automático del código fuente
    options { skipDefaultCheckout() }


    // Estapas del pipeline
    stages{

        //Etapa para obtener el código fuente
        stage('GET CODE'){
            // Paso para clonar el repositorio Git
            steps{
                git 'https://github.com/OscarNFP/cp1.1.git'
                sh '''
                    echo ${WORKSPACE}
                    whoami
                    hostname
                '''
                stash includes: '**', name: 'codigo'
            }
        }

        // Etapa de construcción del proyecto
        stage('BUILD'){
            steps{
                sh 'echo "No hacemos nada, Python no necesita compilación"'
                sh '''
                    echo ${WORKSPACE}
                    whoami
                    hostname
                '''
            }

        }
        stage('TEST'){
            parallel
            {
                stage('UNIT'){
                    agent { label 'agent1' }
                    steps{
                        unstash name: 'codigo'
                        sh '''
                            echo ${WORKSPACE}
                            whoami
                            hostname
                            export PYTHONPATH=${WORKSPACE}
                            /home/oscar/unir_projects/jenkins/agent1/.local/pytest --junitxml=result-unit.xml test/unit
                        '''
                        stash includes: 'result-unit.xml', name: 'resultado-unit'
                    }

                }
                stage('REST'){
                    agent { label 'agent2' }
                    steps{
                        unstash name: 'codigo'
                        sh '''
                            echo ${WORKSPACE}
                            whoami
                            hostname
                            export FLASK_APP=app/api.py
                            /home/oscar/unir_projects/jenkins/agent2/.local/flask run &
                            java -jar /home/oscar/unir_projects/jenkins/agent2/wiremock-standalone-3.13.2.jar --port 9090 --root-dir /home/oscar/unir_projects/jenkins/agent2/wiremock &
                            export PYTHONPATH=$WORKSPACE
                            sleep 10
                            /home/oscar/unir_projects/jenkins/agent2/.local/bin/pytest --junitxml=result-rest.xml test/rest                   
                        '''
                        stash includes: 'result-rest.xml', name: 'resultado-rest'
                    }
                }
            }
        }
        stage ('Results'){
            steps{
                untash name: 'resultado-unit'
                untash name: 'resultado-rest'
                junit 'result*.xml'
            }
        }
    }
}
